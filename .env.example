# Primary — Google AI Studio (free tier)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fallback 1 — Groq (free tier, fast Llama)
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback 2 — OpenRouter (free models via openrouter/free)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Provider order when primary fails (comma-separated)
CHAT_PROVIDER_ORDER=gemini,groq,openrouter

# Telegram — inquiry form forwards to your chat (BotFather + chat id)
# https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Pages — URL of Cloudflare Worker (no trailing slash)
# NEXT_PUBLIC_CHAT_API_URL=https://nyrokume-chat-api.your-subdomain.workers.dev

# Canonical site URL for SEO (Open Graph, sitemap, canonical)
# NEXT_PUBLIC_SITE_URL=https://nyrokume.github.io/nyrokume.dev
